<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0vcs3m3" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.39.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.23.0">
  <bpmn:process id="ai_agent_working_example" name="ai_agent_working_example" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="UserRequestSubmittedStartEvent" name="User Request Submitted">
      <bpmn:documentation>Examples (User Requests):
- What is the exchange rate of the wallet with ID 152 in US dollars?
- A customer is trying to make a purchase of $1,200. Run this through the risk classifier and let me know if it’s approved or if we need a manual review.
- A client just submitted a payment for $850. Can you let me know if this has been approved?</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:executionListener expression="#{execution.setVariable(&#34;userRequest&#34;, execution.hasVariable(&#34;initialRequest&#34;) ? execution.getVariable(&#34;initialRequest&#34;) : &#34;A client just submitted a payment for $850. Can you let me know if this has been approved?&#34;)}" event="start" />
        <camunda:executionListener expression="#{execution.setVariable(&#34;conversationHistory&#34;, null)}" event="start" />
        <camunda:executionListener expression="#{execution.setVariable(&#34;max&#34;, 5)}" event="start" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0rfh4sv</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0rfh4sv" sourceRef="UserRequestSubmittedStartEvent" targetRef="FetchMCPToolsTask" />
    <bpmn:serviceTask id="FetchMCPToolsTask" name="Fetch MCP Tools" camunda:type="external" camunda:topic="wanaku-tools-fetch">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="availableTools">#{availableTools}</camunda:outputParameter>
          <camunda:outputParameter name="iteration">#{1}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0rfh4sv</bpmn:incoming>
      <bpmn:outgoing>Flow_0w6rm4m</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0w6rm4m" sourceRef="FetchMCPToolsTask" targetRef="Gateway_14i9185" />
    <bpmn:serviceTask id="CallLLMTask" name="Call LLM" camunda:type="external" camunda:topic="llm-decision">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="userRequest">#{userRequest}</camunda:inputParameter>
          <camunda:inputParameter name="conversationHistory">#{conversationHistory}</camunda:inputParameter>
          <camunda:inputParameter name="availableTools">#{availableTools}</camunda:inputParameter>
          <camunda:outputParameter name="requiresTool">#{requiresTool}</camunda:outputParameter>
          <camunda:outputParameter name="toolName">#{toolName}</camunda:outputParameter>
          <camunda:outputParameter name="toolArgs">#{toolArgs}</camunda:outputParameter>
          <camunda:outputParameter name="finalAnswer">#{finalAnswer}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0edhwf4</bpmn:incoming>
      <bpmn:outgoing>Flow_1qdzlqu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1qdzlqu" sourceRef="CallLLMTask" targetRef="LLMResponseGateway" />
    <bpmn:exclusiveGateway id="LLMResponseGateway" name="LLM Response?">
      <bpmn:incoming>Flow_1qdzlqu</bpmn:incoming>
      <bpmn:outgoing>RequiresToolSequenceFlow</bpmn:outgoing>
      <bpmn:outgoing>FinalAnswerOrMaxIterationSequenceFlow</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="RequiresToolSequenceFlow" name="Requires Tool" sourceRef="LLMResponseGateway" targetRef="CallMCPToolTask">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{iteration &lt;= max and requiresTool}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="CallMCPToolTask" name="Call MCP Tool" camunda:type="external" camunda:topic="wanaku-tool-execute">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="toolName">#{toolName}</camunda:inputParameter>
          <camunda:inputParameter name="toolArgs">#{toolArgs}</camunda:inputParameter>
          <camunda:outputParameter name="toolResult">#{toolResult}</camunda:outputParameter>
          <camunda:outputParameter name="toolError">#{toolError}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>RequiresToolSequenceFlow</bpmn:incoming>
      <bpmn:outgoing>Flow_0x0eg5g</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0x0eg5g" sourceRef="CallMCPToolTask" targetRef="AppendToolResultToConversationHistoryTask" />
    <bpmn:scriptTask id="AppendToolResultToConversationHistoryTask" name="Append Tool Result to Conversation History" camunda:asyncBefore="true" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="iteration">#{iteration + 1}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0x0eg5g</bpmn:incoming>
      <bpmn:outgoing>Flow_1kr0206</bpmn:outgoing>
      <bpmn:script>var ArrayList = java.util.ArrayList;
var HashMap = java.util.HashMap;
var JSON = org.cibseven.spin.Spin.JSON;

var history = execution.getVariable("conversationHistory");
var historyList = (history == null) ? new ArrayList() : new ArrayList(history);

var toolName = execution.getVariable("toolName");
var toolArgs = execution.getVariable("toolArgs");
var toolResult = execution.getVariable("toolResult");
var toolError = execution.getVariable("toolError");

// 1. Store the LLM's prior decision as an assistant message
var assistantMsg = new HashMap();
assistantMsg.put("role", "assistant");

// Use Camunda Spin to serialize the toolArgs java MAP to literal JSON, gracefully.
var argsJson = (toolArgs != null) ? JSON(toolArgs).toString() : "{}";
var decisionJson = '{"requiresTool":true,"toolName":"' + toolName + '","toolArgs":' + argsJson + ',"finalAnswer":null}';

assistantMsg.put("content", decisionJson);
historyList.add(assistantMsg);

// 2. Store the execution result or error as a user message
var userMsg = new HashMap();
userMsg.put("role", "user");

if (toolError != null) {
    userMsg.put("content", "Tool execution failed for '" + toolName + "'. Error: " + toolError);
} else {
    var rawResult = (toolResult != null) ? toolResult : "No output";
    userMsg.put("content", "Tool '" + toolName + "' execution succeeded. Result:\\n" + rawResult);
}

historyList.add(userMsg);

// 3. Update the Camunda process variable
execution.setVariable("conversationHistory", historyList);</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="FinalAnswerOrMaxIterationSequenceFlow" name="Final Answer or Max Iteration" sourceRef="LLMResponseGateway" targetRef="DisplayResultTask">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{finalAnswer != null or iteration &gt; max}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_1us5n1r">
      <bpmn:incoming>Flow_0z2q61n</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0z2q61n" sourceRef="DisplayResultTask" targetRef="Event_1us5n1r" />
    <bpmn:userTask id="DisplayResultTask" name="Display Result">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="result">#{iteration &gt; max ? (finalAnswer != null ? finalAnswer.concat(' | max iteration reached') : ' Max iteration reached') : finalAnswer}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>FinalAnswerOrMaxIterationSequenceFlow</bpmn:incoming>
      <bpmn:outgoing>Flow_0z2q61n</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_14i9185">
      <bpmn:incoming>Flow_0w6rm4m</bpmn:incoming>
      <bpmn:incoming>Flow_1kr0206</bpmn:incoming>
      <bpmn:outgoing>Flow_0edhwf4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0edhwf4" sourceRef="Gateway_14i9185" targetRef="CallLLMTask" />
    <bpmn:sequenceFlow id="Flow_1kr0206" sourceRef="AppendToolResultToConversationHistoryTask" targetRef="Gateway_14i9185" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
