        <bpmndi:BPMNLabel>
          <dc:Bounds x="136" y="255" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1l79t8c_di" bpmnElement="FetchMCPToolsTask">
        <dc:Bounds x="270" y="190" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_1mfbdj6" bpmnElement="CallLLMTask">
        <dc:Bounds x="540" y="190" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_0t51jfs_di" bpmnElement="LLMResponseGateway" isMarkerVisible="true">
        <dc:Bounds x="755" y="205" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="680" y="193" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1xtga4l_di" bpmnElement="CallMCPToolTask">
        <dc:Bounds x="930" y="190" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1qdr1mz_di" bpmnElement="AppendToolResultToConversationHistoryTask">
        <dc:Bounds x="1110" y="190" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1us5n1r_di" bpmnElement="Event_1us5n1r">
        <dc:Bounds x="1142" y="322" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1hvgx0g_di" bpmnElement="DisplayResultTask">
        <dc:Bounds x="930" y="300" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_14i9185_di" bpmnElement="Gateway_14i9185" isMarkerVisible="true">
        <dc:Bounds x="425" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_0rfh4sv_di" bpmnElement="Flow_0rfh4sv">
        <di:waypoint x="188" y="230" />
        <di:waypoint x="270" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0w6rm4m_di" bpmnElement="Flow_0w6rm4m">
        <di:waypoint x="370" y="230" />
        <di:waypoint x="425" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1qdzlqu_di" bpmnElement="Flow_1qdzlqu">
        <di:waypoint x="640" y="230" />
        <di:waypoint x="755" y="230" />
      </bpmndi:BPMNEdge>
